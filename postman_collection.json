    {
      "name": "Usuarios",
      "description": "Registro e autenticacao.",
      "item": [
        {
          "name": "Registro",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Employee\",\n  \"email\": \"john.employee@company.com\",\n  \"password\": \"StrongP@ssw0rd!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register"
              ]
            },
            "description": "Cria novo usuario no sistema."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status deve ser 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  const token = data.accessToken || data.token || (data.data && data.data.accessToken);",
                  "",
                  "  pm.test('Token JWT retornado', function () {",
                  "    pm.expect(token).to.be.a('string');",
                  "    pm.expect(token.length).to.be.greaterThan(0);",
                  "  });",
                  "",
                  "  if (token) {",
                  "    pm.globals.set('jwt_token', token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.employee@company.com\",\n  \"password\": \"StrongP@ssw0rd!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Autentica usuario e salva o JWT em variavel global jwt_token."
          },
          "response": []
        }
      ]
    },
